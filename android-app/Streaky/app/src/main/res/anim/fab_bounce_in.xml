<?xml version="1.0" encoding="utf-8"?>
<!--
    fab_bounce_in.xml — res/anim/
    FAB launch animation: scale from 0→1 with overshoot bounce + fade in.
    Used in MainActivity with a 300ms start delay.

    Overshoot interpolator gives the "elastic pop" feel:
    the FAB briefly scales past 1.0 before settling.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/overshoot_interpolator"
    android:fillAfter="true">

    <!-- Scale: 0 → 1.0 (pivoted at centre) -->
    <scale
        android:fromXScale="0.0"
        android:toXScale="1.0"
        android:fromYScale="0.0"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="400"
        android:startOffset="300" />

    <!-- Fade: 0 → 1 -->
    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="200"
        android:startOffset="300" />

</set>
