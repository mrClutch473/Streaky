<?xml version="1.0" encoding="utf-8"?>
<!--
    fab_slide_down.xml — res/animator/
    ObjectAnimator: translates the FAB downward by 200dp + fades out.
    Used when hiding the FAB on scroll-down events.
    AnimatorSet is applied via AnimatorInflater or constructed in code.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:ordering="together">

    <objectAnimator
        android:propertyName="translationY"
        android:valueTo="200"
        android:valueType="floatType"
        android:duration="250"
        android:interpolator="@android:interpolator/fast_out_linear_in" />

    <objectAnimator
        android:propertyName="alpha"
        android:valueTo="0"
        android:valueType="floatType"
        android:duration="200"
        android:interpolator="@android:interpolator/fast_out_linear_in" />

</set>
