<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_check.xml — res/drawable/
    Bold checkmark — shown inside completeButton when habit is done.
    Tint applied at runtime: #FFFFFF (onPrimary).
    Stroke weight matches Material Symbols "check" — 2.5px visual weight.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Check path: starts bottom-left of the tick, goes up-right to
        the elbow, then sweeps up-right to the top-right tip.
        Rounded stroke caps give a softer, modern feel.
    -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M4.5,12.5 L9.5,17.5 L19.5,7.5" />

</vector>
