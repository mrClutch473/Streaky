<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_circle_outline.xml — res/drawable/
    A simple unfilled circle — used as the "unchecked" icon
    inside completeButton when the habit is not yet done today.
    Tint applied at runtime: #9E9E9E (onSurfaceVariant).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Stroke-only circle: drawn as a ring using fillType="evenOdd"
        trick — outer circle minus inner circle = ring shape.
    -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="
            M12,2
            A10,10 0 1,0 12,22
            A10,10 0 1,0 12,2
            Z
            M12,4
            A8,8 0 1,1 12,20
            A8,8 0 1,1 12,4
            Z"
        android:fillType="evenOdd" />

</vector>
