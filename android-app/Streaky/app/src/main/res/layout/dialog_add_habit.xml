<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_add_habit.xml
    Streaky — Add Habit Bottom Sheet Layout
    Root: ConstraintLayout inside NestedScrollView for keyboard-safe scrolling.
    Background shape (bg_bottom_sheet) applies top-28dp rounded corners.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomSheetRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="36dp"
        tools:background="@color/md_theme_dark_surface">

        <!-- ═══════════════════════════════════════════════
             1. DRAG HANDLE
             40×4dp pill, colour #9E9E9E, centred top
             ═══════════════════════════════════════════════ -->
        <View
            android:id="@+id/dragHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_drag_handle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════
             2. TITLE  "Новая привычка"
             textAppearanceTitleLarge · white
             ═══════════════════════════════════════════════ -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/add_habit_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@color/md_theme_dark_onBackground"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/dragHandle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════
             3. TEXT INPUT  — Habit name
             OutlinedBox · corner 12dp · counter 30
             Outline default #9E9E9E / focused #4CAF50
             ═══════════════════════════════════════════════ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilHabitName"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/habit_name_hint"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/selector_outline_color"
            app:boxStrokeErrorColor="@color/streaky_error"
            app:hintTextColor="@color/selector_hint_color"
            app:counterEnabled="true"
            app:counterMaxLength="30"
            app:counterTextColor="@color/md_theme_dark_onSurfaceVariant"
            app:endIconMode="clear_text"
            app:endIconTint="@color/md_theme_dark_onSurfaceVariant"
            app:placeholderTextColor="@color/md_theme_dark_onSurfaceVariant"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHabitName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_dark_onBackground"
                android:textCursorDrawable="@drawable/cursor_green"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:imeOptions="actionDone"
                android:maxLength="30" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ═══════════════════════════════════════════════
             4. SECTION LABEL  "Выбери иконку"
             textAppearanceLabelMedium · #9E9E9E
             ═══════════════════════════════════════════════ -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvIconLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/choose_icon_label"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="@color/md_theme_dark_onSurfaceVariant"
            android:letterSpacing="0.04"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tilHabitName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════
             5. ICON SELECTOR  — HorizontalScrollView
             Negative side margins escape ConstraintLayout
             padding so icons bleed to screen edges.
             Inner LinearLayout is populated programmatically
             in AddHabitDialog.kt (buildEmojiIcons).
             ═══════════════════════════════════════════════ -->
        <HorizontalScrollView
            android:id="@+id/hsvIcons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipToPadding="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginStart="-24dp"
            android:layout_marginEnd="-24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvIconLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/iconsContainer"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false" />

        </HorizontalScrollView>

        <!-- ═══════════════════════════════════════════════
             6. PRIMARY ACTION BUTTON
             52dp height · corner 14dp · green accent bg
             Disabled until habit name is non-empty.
             Text colour uses selector (white/grey).
             ═══════════════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddHabit"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="@string/add_habit_button"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@color/selector_button_text"
            android:enabled="false"
            android:layout_marginTop="28dp"
            app:backgroundTint="@color/selector_button_bg"
            app:cornerRadius="14dp"
            app:rippleColor="@color/streaky_ripple"
            app:layout_constraintTop_toBottomOf="@id/hsvIcons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
