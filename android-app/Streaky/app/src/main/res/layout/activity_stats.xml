<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_stats.xml
    Streaky — Habit Statistics Screen
    CoordinatorLayout → AppBarLayout/MaterialToolbar + NestedScrollView
    Calendar grid (calendarGrid) is populated programmatically in StatsActivity.kt
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_dark_background"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════════════════════════════
         1. APP BAR / TOOLBAR
         Elevation 0 — flat dark header; no shadow on dark bg.
         ═══════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_dark_background"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/md_theme_dark_background"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/md_theme_dark_onBackground"
            app:titleTextColor="@color/md_theme_dark_onBackground"
            app:titleTextAppearance="?attr/textAppearanceTitleMedium"
            app:subtitleTextColor="@color/md_theme_dark_onSurfaceVariant"
            tools:title="Выпить воды" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         SCROLLABLE CONTENT
         ═══════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- ─────────────────────────────────────────────────────────────
                 2. HERO BLOCK — Emoji + streak counter
                 alpha=0 initially; fade+scale entrance driven from Kotlin
                 ───────────────────────────────────────────────────────────── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/heroBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp"
                android:alpha="0">

                <!-- Habit emoji — shared element from main screen card -->
                <TextView
                    android:id="@+id/tvHabitIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="64sp"
                    android:includeFontPadding="false"
                    android:transitionName="@string/transition_habit_icon"
                    tools:text="💧"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Streak row: 🔥 [number] дней подряд -->
                <LinearLayout
                    android:id="@+id/streakRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tvHabitIcon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tvFireEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="30sp"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="6dp" />

                    <!-- CountUp target — animated 0 → streak value -->
                    <TextView
                        android:id="@+id/tvStreakNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textAppearance="?attr/textAppearanceHeadlineLarge"
                        android:textColor="@color/streaky_secondary"
                        android:textStyle="bold"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="8dp"
                        tools:text="6" />

                    <TextView
                        android:id="@+id/tvStreakSuffix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/days_in_a_row"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="4dp" />

                </LinearLayout>

                <!-- Thin divider rule #2A2A2A -->
                <View
                    android:id="@+id/heroDivider"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/streaky_divider"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/streakRow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ─────────────────────────────────────────────────────────────
                 3. STAT TILES ROW — Сейчас / Рекорд / Всего
                 alpha=0 initially; slideUp staggered from Kotlin
                 Margins applied here; equal weight distribution via weightSum
                 ───────────────────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/statTilesRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="4dp">

                <!-- Tile: Сейчас (#FF6B35 orange) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileNow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:alpha="0"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/md_theme_dark_surface"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvStatNow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/streaky_secondary"
                            android:textStyle="bold"
                            tools:text="6" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_current"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/md_theme_dark_onSurfaceVariant"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tile: Рекорд (#FFD700 gold) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileBest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:alpha="0"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/md_theme_dark_surface"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvStatBest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/streaky_gold"
                            android:textStyle="bold"
                            tools:text="14" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_record"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/md_theme_dark_onSurfaceVariant"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tile: Всего (#4CAF50 green) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:alpha="0"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/md_theme_dark_surface"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvStatTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/md_theme_dark_primary"
                            android:textStyle="bold"
                            tools:text="21" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_total"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/md_theme_dark_onSurfaceVariant"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ─────────────────────────────────────────────────────────────
                 4. CALENDAR CARD — Last 30 days
                 alpha=0; fades in as a block (300ms, 200ms delay)
                 GridLayout is populated programmatically in buildCalendarGrid()
                 ───────────────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/calendarCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:alpha="0"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/md_theme_dark_surface"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvCalendarTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/last_30_days"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant"
                        android:letterSpacing="0.03"
                        android:layout_marginBottom="14dp" />

                    <!-- Populated programmatically: 6 cols × 5 rows = 30 cells -->
                    <GridLayout
                        android:id="@+id/calendarGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="6"
                        android:rowCount="5"
                        android:useDefaultMargins="false"
                        android:alignmentMode="alignMargins" />

                    <!-- "X дней из 30" summary text -->
                    <TextView
                        android:id="@+id/tvCompletionSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant"
                        tools:text="18 дней из 30" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────────────────────────────
                 5. DELETE BUTTON — OutlinedButton, red (#CF6679)
                 ───────────────────────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteHabit"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:text="@string/delete_habit"
                android:textColor="@color/streaky_error"
                app:icon="@drawable/ic_delete_outline"
                app:iconTint="@color/streaky_error"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:strokeColor="@color/streaky_error"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                app:rippleColor="@color/streaky_error_ripple" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
