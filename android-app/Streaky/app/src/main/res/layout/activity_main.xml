<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Streaky Habit Tracker
    Main screen: AppBar + RecyclerView + FAB + EmptyState
    Material Design 3 · Dark Theme · ConstraintLayout inside CoordinatorLayout
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_dark_background"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════
         APP BAR
         ══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_dark_background"
        android:fitsSystemWindows="true"
        app:elevation="0dp"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/habitsRecyclerView">

        <!--
            CollapsingToolbarLayout allows a subtle parallax shift on scroll.
            expandedTitleTextAppearance is set to transparent so we draw
            the title manually inside the Toolbar for full layout control.
        -->
        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:expandedTitleTextAppearance="@style/TextAppearance.Streaky.Transparent"
            app:collapsedTitleTextAppearance="@style/TextAppearance.Streaky.Transparent"
            app:contentScrim="@color/md_theme_dark_background"
            app:scrimAnimationDuration="300">

            <!-- ── Toolbar inner content ── -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                app:layout_collapseMode="pin">

                <!-- Full-width title row with fire icon + date -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/toolbarContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- 🔥 Fire icon -->
                    <ImageView
                        android:id="@+id/fireIconView"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_fire"
                        android:contentDescription="@string/fire_icon_description"
                        android:scaleType="fitCenter"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <!-- "Streaky" headline title -->
                    <TextView
                        android:id="@+id/appTitleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                        android:textColor="@color/md_theme_dark_onBackground"
                        android:textSize="28sp"
                        android:fontFamily="@font/inter_regular"
                        android:layout_marginStart="10dp"
                        app:layout_constraintStart_toEndOf="@id/fireIconView"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <!-- Current date subtitle -->
                    <TextView
                        android:id="@+id/currentDateText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        tools:text="Понедельник, 12 мая"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant"
                        android:textSize="13sp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:layout_constraintStart_toStartOf="@id/appTitleText"
                        app:layout_constraintTop_toBottomOf="@id/appTitleText"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginBottom="2dp" />

                    <!--
                        ConstraintLayout won't naturally stack items vertically
                        in one pass when the parent is match_parent height.
                        We centre the group of [title + date] together.
                        Solution: wrap them in a vertical LinearLayout.
                    -->

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.appcompat.widget.Toolbar>

            <!--
                EXPANDED header area (visible when scrolled to top).
                Shows the grouped title + date with generous vertical padding.
            -->
            <LinearLayout
                android:id="@+id/expandedHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="12dp"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5">

                <!-- Row: fire emoji + "Streaky" -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_fire"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineLarge"
                        android:textColor="@color/md_theme_dark_onBackground"
                        android:textSize="34sp"
                        android:layout_marginStart="10dp" />

                </LinearLayout>

                <!-- Date subtitle below -->
                <TextView
                    android:id="@+id/expandedDateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Понедельник, 12 мая"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="@color/md_theme_dark_onSurfaceVariant"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════
         SCROLLABLE CONTENT AREA
         ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- ── Habits RecyclerView ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/habitsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="30dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                tools:listitem="@layout/item_habit"
                tools:itemCount="5"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- ══════════════════════════════════════════
                 EMPTY STATE — shown when no habits exist
                 Default: GONE, animated in via code
                 ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingBottom="64dp"
                android:visibility="gone"
                android:alpha="0"
                tools:visibility="visible">

                <!-- Sprout emoji — 72sp -->
                <TextView
                    android:id="@+id/emptyStateEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_state_emoji"
                    android:textSize="72sp"
                    android:lineSpacingExtra="0dp"
                    android:includeFontPadding="false" />

                <!-- "Нет привычек" -->
                <TextView
                    android:id="@+id/emptyStateTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_state_title"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textColor="@color/md_theme_dark_onBackground"
                    android:layout_marginTop="20dp"
                    android:gravity="center" />

                <!-- Hint text -->
                <TextView
                    android:id="@+id/emptyStateSubtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_state_subtitle"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/md_theme_dark_onSurfaceVariant"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </FrameLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════
         EXTENDED FAB — "+ Привычка"
         Position: bottom-end, margin 24dp
         Behavior: hide on scroll down, show on scroll up
         ══════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/addHabitFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="20dp"
        android:text="@string/fab_add_habit"
        android:textColor="@color/md_theme_dark_onPrimary"
        android:textSize="20sp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="11dp"
        android:paddingBottom="10dp"
        android:contentDescription="@string/fab_add_habit_description"
        app:icon="@drawable/ic_add"
        app:iconTint="@color/md_theme_dark_onPrimary"
        app:iconSize="32dp"
        app:iconPadding="8dp"
        app:backgroundTint="@color/md_theme_dark_primary"
        app:cornerRadius="18dp"
        app:elevation="8dp"
        app:hoveredFocusedTranslationZ="2dp"
        app:pressedTranslationZ="4dp"
        android:scaleX="0"
        android:scaleY="0"
        android:alpha="0" />
    <!--
        Initial scale=0 / alpha=0: the FAB is invisible at launch.
        MainActivity will trigger a bounce-in animation after 300ms delay.

        NOTE: FloatingActionButton.Behavior (hide/show on scroll) is
        handled programmatically in MainActivity via OnScrollListener
        for precise control with NestedScrollView.
    -->

</androidx.coordinatorlayout.widget.CoordinatorLayout>