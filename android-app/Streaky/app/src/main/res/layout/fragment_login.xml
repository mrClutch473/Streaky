<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_login.xml — Streaky
    ─────────────────────────────────────────────────────────────────────────────
    Login form: Email + Password + "Войти" button + "Забыли пароль?"

    Layout structure:
        NestedScrollView (keyboard-safe)
        └── ConstraintLayout (padding 24dp h, 32dp top)
            ├── "С возвращением 👋"  headline
            ├── subtitle             BodyMedium · onSurfaceVariant
            ├── tilEmail             OutlinedBox TextInputLayout
            ├── tilPassword          OutlinedBox + password toggle
            ├── btnForgotPassword    TextButton · right-aligned
            ├── btnLogin             filled · green · 52dp
            └── bottom gap spacer
    ─────────────────────────────────────────────────────────────────────────────
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_dark_background"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        tools:background="@color/md_theme_dark_background">

        <!-- ══════════════════════════════════════════════════════════
             GREETING HEADLINE
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/loginHeadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="С возвращением 👋"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="@color/md_theme_dark_onBackground"
            android:fontFamily="@font/inter_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/loginSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Войдите, чтобы продолжить строить стрики"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/md_theme_dark_onSurfaceVariant"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/loginHeadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════════════════════════
             EMAIL FIELD
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLoginEmail"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Электронная почта"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/selector_outline_color"
            app:hintTextColor="@color/selector_hint_color"
            app:startIconDrawable="@drawable/ic_email_outline"
            app:startIconTint="@color/md_theme_dark_onSurfaceVariant"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/loginSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLoginEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_dark_onBackground"
                android:textCursorDrawable="@drawable/cursor_green"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:imeOptions="actionNext"
                android:autofillHints="emailAddress" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════════════════
             PASSWORD FIELD — with show/hide toggle
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLoginPassword"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Пароль"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/selector_outline_color"
            app:hintTextColor="@color/selector_hint_color"
            app:startIconDrawable="@drawable/ic_lock_outline"
            app:startIconTint="@color/md_theme_dark_onSurfaceVariant"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/md_theme_dark_onSurfaceVariant"
            app:passwordToggleDrawable="@drawable/ic_visibility_selector"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tilLoginEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLoginPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_dark_onBackground"
                android:textCursorDrawable="@drawable/cursor_green"
                android:inputType="textPassword"
                android:maxLines="1"
                android:imeOptions="actionDone"
                android:autofillHints="password" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════════════════
             FORGOT PASSWORD — right-aligned TextButton
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnForgotPassword"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Забыли пароль?"
            android:textColor="@color/md_theme_dark_primary"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            app:rippleColor="@color/ripple_on_surface"
            android:paddingStart="0dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tilLoginPassword"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════════════════════════
             LOGIN BUTTON — primary action
             Full width · 52dp · green · 14dp corner
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="Войти"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="@color/md_theme_dark_onPrimary"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            app:backgroundTint="@color/md_theme_dark_primary"
            app:cornerRadius="14dp"
            app:rippleColor="@color/streaky_ripple"
            app:layout_constraintTop_toBottomOf="@id/btnForgotPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════════════════════════
             ERROR MESSAGE — hidden by default, shown by code
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/loginErrorCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/streaky_error_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/streaky_error"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_error_outline"
                    app:tint="@color/streaky_error"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvLoginError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/streaky_error"
                    android:layout_marginStart="8dp"
                    tools:text="Неверный email или пароль" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>