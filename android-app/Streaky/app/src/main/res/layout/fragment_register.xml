<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_register.xml — Streaky
    ─────────────────────────────────────────────────────────────────────────────
    Registration form: Name + Email + Password + Confirm + CTA

    Layout structure:
        NestedScrollView (keyboard-safe scrolling)
        └── ConstraintLayout (padding 24dp h, 32dp top)
            ├── "Создай аккаунт 🚀"  HeadlineSmall · white
            ├── subtitle              BodyMedium · onSurfaceVariant
            ├── tilName               OutlinedBox — имя пользователя
            ├── tilEmail              OutlinedBox — e-mail
            ├── tilPassword           OutlinedBox — пароль + toggle
            ├── tilConfirmPassword    OutlinedBox — повтор пароля + toggle
            ├── password hint chips   (BodySmall · muted — требования к паролю)
            ├── btnRegister           filled green · 52dp
            └── privacy note          BodySmall · onSurfaceVariant · centered
    ─────────────────────────────────────────────────────────────────────────────
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_dark_background"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        tools:background="@color/md_theme_dark_background">

        <!-- ══════════════════════════════════════════════════════════
             GREETING HEADLINE
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/registerHeadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Создай аккаунт 🚀"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="@color/md_theme_dark_onBackground"
            android:fontFamily="@font/inter_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/registerSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Начни отслеживать привычки и строй стрики"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/md_theme_dark_onSurfaceVariant"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/registerHeadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════════════════════════
             EMAIL FIELD
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRegisterEmail"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Электронная почта"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/selector_outline_color"
            app:hintTextColor="@color/selector_hint_color"
            app:startIconDrawable="@drawable/ic_email_outline"
            app:startIconTint="@color/md_theme_dark_onSurfaceVariant"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/registerSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegisterEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_dark_onBackground"
                android:textCursorDrawable="@drawable/cursor_green"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:imeOptions="actionNext"
                android:autofillHints="emailAddress" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════════════════
             PASSWORD FIELD
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRegisterPassword"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Пароль"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/selector_outline_color"
            app:boxStrokeErrorColor="@color/streaky_error"
            app:hintTextColor="@color/selector_hint_color"
            app:startIconDrawable="@drawable/ic_lock_outline"
            app:startIconTint="@color/md_theme_dark_onSurfaceVariant"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/md_theme_dark_onSurfaceVariant"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tilRegisterEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegisterPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_dark_onBackground"
                android:textCursorDrawable="@drawable/cursor_green"
                android:inputType="textPassword"
                android:maxLines="1"
                android:imeOptions="actionNext"
                android:autofillHints="newPassword" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════════════════
             CONFIRM PASSWORD FIELD
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRegisterConfirmPassword"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Повторите пароль"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/selector_outline_color"
            app:boxStrokeErrorColor="@color/streaky_error"
            app:hintTextColor="@color/selector_hint_color"
            app:startIconDrawable="@drawable/ic_lock_check_outline"
            app:startIconTint="@color/md_theme_dark_onSurfaceVariant"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/md_theme_dark_onSurfaceVariant"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tilRegisterPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegisterConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_dark_onBackground"
                android:textCursorDrawable="@drawable/cursor_green"
                android:inputType="textPassword"
                android:maxLines="1"
                android:imeOptions="actionDone"
                android:autofillHints="newPassword" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════════════════
             PASSWORD STRENGTH ROW — 4 mini segments
             Animated via code: grey → orange → green as user types.
             ══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/passwordStrengthRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tilRegisterConfirmPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 4 segments — tint controlled from code -->
            <View
                android:id="@+id/strengthSeg1"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_strength_segment"
                android:backgroundTint="@color/md_theme_dark_surfaceVariant"
                android:layout_marginEnd="4dp" />

            <View
                android:id="@+id/strengthSeg2"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_strength_segment"
                android:backgroundTint="@color/md_theme_dark_surfaceVariant"
                android:layout_marginEnd="4dp" />

            <View
                android:id="@+id/strengthSeg3"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_strength_segment"
                android:backgroundTint="@color/md_theme_dark_surfaceVariant"
                android:layout_marginEnd="4dp" />

            <View
                android:id="@+id/strengthSeg4"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_strength_segment"
                android:backgroundTint="@color/md_theme_dark_surfaceVariant" />

            <!-- Label: "Слабый" / "Средний" / "Надёжный" -->
            <TextView
                android:id="@+id/tvPasswordStrengthLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/md_theme_dark_onSurfaceVariant"
                android:layout_marginStart="10dp"
                tools:text="Средний" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════
             ERROR CARD — hidden by default, shown by code
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/registerErrorCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/streaky_error_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/streaky_error"
            app:layout_constraintTop_toBottomOf="@id/passwordStrengthRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_error_outline"
                    app:tint="@color/streaky_error"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvRegisterError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/streaky_error"
                    android:layout_marginStart="8dp"
                    tools:text="Пароли не совпадают" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════
             REGISTER BUTTON — primary action
             ══════════════════════════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="Создать аккаунт"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="@color/md_theme_dark_onPrimary"
            android:textSize="16sp"
            android:enabled="false"
            android:layout_marginTop="20dp"
            app:backgroundTint="@color/selector_button_bg"
            app:cornerRadius="14dp"
            app:rippleColor="@color/streaky_ripple"
            app:layout_constraintTop_toBottomOf="@id/registerErrorCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══════════════════════════════════════════════════════════
             PRIVACY NOTE — below button, small grey text
             ══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvPrivacyNote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Регистрируясь, вы принимаете условия использования и политику конфиденциальности"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/md_theme_dark_onSurfaceVariant"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/btnRegister"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>