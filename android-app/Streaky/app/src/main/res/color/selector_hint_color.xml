<?xml version="1.0" encoding="utf-8"?>
<!--
    res/color/selector_hint_color.xml
    Hint / floating label colour for TextInputLayout.
    Focused  → md_theme_dark_primary
    Default  → md_theme_dark_onSurfaceVariant
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:color="@color/md_theme_dark_primary"
        android:state_focused="true" />

    <item android:color="@color/md_theme_dark_onSurfaceVariant" />

</selector>
